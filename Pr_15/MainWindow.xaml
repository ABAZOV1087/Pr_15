<Window x:Class="Pr_15.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="Каталог комплектующих" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="5">
                    <TextBox x:Name="TxtSearch" Width="200" Margin="5" TextChanged="UpdateFilters" />
                    <ComboBox x:Name="ComboCategory" Width="150" Margin="5" SelectionChanged="UpdateFilters" DisplayMemberPath="Name" />
                    <ComboBox x:Name="ComboBrand" Width="150" Margin="5" SelectionChanged="UpdateFilters" DisplayMemberPath="Name" />
                </StackPanel>

                <ListView x:Name="LvComponents" Grid.Row="1" Margin="5" d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Наименование" DisplayMemberBinding="{Binding FullName}" Width="250"/>
                            <GridViewColumn Header="Характеристики" DisplayMemberBinding="{Binding Socket}" Width="100"/>
                            <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding DisplayPrice}" Width="100"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <Button Content="Добавить в сборку" Grid.Row="2" Height="35" Margin="5" Click="BtnAdd_Click"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Текущая конфигурация" Grid.Column="1" Margin="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="5">
                    <TextBlock x:Name="TbTotal" Text="Итого: 0 руб." FontSize="18" FontWeight="Bold" Margin="5"/>
                    <TextBox x:Name="TxtBuildName" Margin="5" Tag="Название сборки"/>
                    <Button Content="Сохранить сборку" Height="40" Background="LightGreen" Click="BtnSave_Click"/>
                    <Button Content="История сборок" Click="BtnOpenHistory_Click" Margin="5" Height="30"/>
                </StackPanel>

                <ListBox x:Name="LbCurrentBuild" DisplayMemberPath="FullName"/>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
